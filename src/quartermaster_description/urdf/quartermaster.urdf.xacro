<?xml version="1.0"?>

<robot name="quartermaster"
    xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:property name="pi" value="3.14159"/>

    <link name="world"/>

    <joint name="world_to_table_joint" type="fixed">
        <parent link="world"/>
        <child link="table_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="table_link">
        <visual>
            <origin xyz="0 0 0.4" rpy="0 0 0"/>
            <geometry>
                <box size="1.0 1.0 0.8"/>
            </geometry>
            <material name="dark_grey">
                <color rgba="0.2 0.2 0.2 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.4" rpy="0 0 0"/>
            <geometry>
                <box size="1.0 1.0 0.8"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.4" rpy="0 0 0"/>
            <mass value="50.0"/>
            <inertia ixx="7.33" ixy="0.0" ixz="0.0" iyy="7.33" iyz="0.0" izz="8.33"/>
        </inertial>
    </link>

    <joint name="table_to_base_joint" type="fixed">
        <parent link="table_link"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.8" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.1" length="0.1"/>
            </geometry>
            <material name="blue">
                <color rgba="0.0 0.0 0.8 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.1" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.0167" ixy="0.0" ixz="0.0" iyy="0.0167" iyz="0.0" izz="0.025"/>
        </inertial>
    </link>

    <joint name="joint_1" type="revolute">
        <parent link="base_link"/>
        <child link="link_1"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100.0" velocity="2.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link_1">
        <visual>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.08" length="0.3"/>
            </geometry>
            <material name="orange">
                <color rgba="1.0 0.5 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.08" length="0.3"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <mass value="3.5"/>
            <inertia ixx="0.028" ixy="0.0" ixz="0.0" iyy="0.028" iyz="0.0" izz="0.011"/>
        </inertial>
    </link>

    <joint name="joint_2" type="revolute">
        <parent link="link_1"/>
        <child link="link_2"/>
        <origin xyz="0 0 0.3" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.5708" upper="1.5708" effort="150.0" velocity="1.5"/>
        <dynamics damping="0.2" friction="0.2"/>
    </joint>

    <link name="link_2">
        <visual>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.06" length="0.4"/>
            </geometry>
            <material name="silver">
                <color rgba="0.8 0.8 0.8 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.06" length="0.4"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <mass value="4.0"/>
            <inertia ixx="0.0569" ixy="0.0" ixz="0.0" iyy="0.0569" iyz="0.0" izz="0.0072"/>
        </inertial>
    </link>

    <joint name="joint_3" type="revolute">
        <parent link="link_2"/>
        <child link="link_3"/>
        <origin xyz="0 0 0.4" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.0" upper="2.0" effort="100.0" velocity="2.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link_3">
        <visual>
            <origin xyz="0 0 0.175" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.35"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.175" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.35"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.175" rpy="0 0 0"/>
            <mass value="2.5"/>
            <inertia ixx="0.027" ixy="0.0" ixz="0.0" iyy="0.027" iyz="0.0" izz="0.0031"/>
        </inertial>
    </link>

    <joint name="joint_4" type="revolute">
        <parent link="link_3"/>
        <child link="link_4"/>
        <origin xyz="0 0 0.35" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="50.0" velocity="2.5"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link_4">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.04" length="0.1"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.04" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <mass value="1.2"/>
            <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="joint_5" type="revolute">
        <parent link="link_4"/>
        <child link="link_5"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.754" upper="1.754" effort="40.0" velocity="3.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link_5">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.035" length="0.1"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.035" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.0011" ixy="0.0" ixz="0.0" iyy="0.0011" iyz="0.0" izz="0.0006"/>
        </inertial>
    </link>

    <joint name="joint_6" type="revolute">
        <parent link="link_5"/>
        <child link="link_6"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="20.0" velocity="3.5"/>
        <dynamics damping="0.05" friction="0.05"/>
    </joint>

    <link name="link_6">
        <visual>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.02"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.02"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <mass value="0.3"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0002"/>
        </inertial>
    </link>


    <!-- ============ GRIPPER ============ -->

    <!-- Palm: rigidly bolted to the wrist (link_6) -->
    <joint name="gripper_base_joint" type="fixed">
        <parent link="link_6"/>
        <child link="gripper_base_link"/>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </joint>

    <link name="gripper_base_link">
        <visual>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <geometry>
                <box size="0.10 0.04 0.02"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <geometry>
                <box size="0.10 0.04 0.02"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <mass value="0.2"/>
            <inertia ixx="0.00003" ixy="0.0" ixz="0.0" iyy="0.00017" iyz="0.0" izz="0.00019"/>
        </inertial>
    </link>

    <!-- Left finger: the ACTIVE joint (slides outward along +x) -->
    <joint name="left_finger_joint" type="prismatic">
        <parent link="gripper_base_link"/>
        <child link="left_finger_link"/>
        <origin xyz="0.005 0 0.02" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="0.0" upper="0.04" effort="50.0" velocity="0.1"/>
    </joint>

    <link name="left_finger_link">
        <visual>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.02 0.06"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.02 0.06"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <mass value="0.05"/>
            <inertia ixx="0.000017" ixy="0.0" ixz="0.0" iyy="0.000015" iyz="0.0" izz="0.000002"/>
        </inertial>
    </link>

    <!-- Right finger: MIMICS the left, sliding the opposite direction (-x) -->
    <joint name="right_finger_joint" type="prismatic">
        <parent link="gripper_base_link"/>
        <child link="right_finger_link"/>
        <origin xyz="-0.005 0 0.02" rpy="0 0 0"/>
        <axis xyz="-1 0 0"/>
        <limit lower="0.0" upper="0.04" effort="50.0" velocity="0.1"/>
        <mimic joint="left_finger_joint" multiplier="1.0" offset="0.0"/>
    </joint>

    <link name="right_finger_link">
        <visual>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.02 0.06"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.02 0.06"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
            <mass value="0.05"/>
            <inertia ixx="0.000017" ixy="0.0" ixz="0.0" iyy="0.000015" iyz="0.0" izz="0.000002"/>
        </inertial>
    </link>

    <!-- Tool Center Point: the frame MTC will aim at the object (between the fingertips) -->
    <joint name="gripper_tcp_joint" type="fixed">
        <parent link="gripper_base_link"/>
        <child link="gripper_tcp_link"/>
        <origin xyz="0 0 0.06" rpy="0 0 0"/>
    </joint>

    <link name="gripper_tcp_link"/>

    <!--GAZEBO TAGS -->


    <ros2_control name="SortingRobotHardwareInterface" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name="joint_1">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint_2">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint_3">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint_4">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint_5">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint_6">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>



    <gazebo>
        <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find quartermaster_gazebo)/config/quartermaster_controllers.yaml</parameters>
        </plugin>
    </gazebo>
</robot>